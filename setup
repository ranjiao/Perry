#!/usr/bin/env bash
# Perry setup — install perry/ + link child skills (okr, pmo, design)
# as siblings so the host (Claude Code at ~/.claude/skills/, Codex CLI at
# ~/.agents/skills/) surfaces /perry, /okr, /pmo, /design.
#
# Both hosts read SKILL.md frontmatter natively for skill discovery; the
# install is just a symlink in the host's canonical skills directory.
set -e

SETUP_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_DIR="$(cd "$(dirname "$0")" && pwd -P)"   # resolves symlinks

# ─── Parse flags ──────────────────────────────────────────────
LOCAL=0
QUIET=0
CODEX=0
while [ $# -gt 0 ]; do
  case "$1" in
    --local)  LOCAL=1; shift ;;
    --codex)  CODEX=1; shift ;;
    --quiet)  QUIET=1; shift ;;
    -h|--help)
      cat <<'USAGE'
Perry setup — register the Perry skill set with your host (Claude Code or Codex CLI).

Usage: setup [--local] [--codex] [--quiet]

  (no flag)   Claude Code, global: install to ~/.claude/skills/
  --local     Claude Code, per-project: install to ./.claude/skills/
  --codex     Also install to ~/.agents/skills/ for Codex CLI.
              Codex discovers SKILL.md natively (no AGENTS.md routing
              needed). Combine with or without --local.
  --quiet     Suppress non-error output

What it does:
  For each target skills directory (~/.claude/skills/ for Claude Code,
  ~/.agents/skills/ for Codex with --codex):
    1. Symlinks perry/ → this script's source.
    2. Symlinks each child skill (okr, pmo, design) as a sibling pointing
       at perry/<name>, so each shows up as a top-level invocable skill.

  With --codex, also prints recommended PERRY_HOME / PERRY_HOST shell
  exports if they're not already set.

Re-running is safe and idempotent: existing symlinks are updated; existing
real files/directories at any target are left untouched (and reported).
USAGE
      exit 0 ;;
    *) echo "Unknown flag: $1 (try --help)" >&2; exit 1 ;;
  esac
done

log() { [ "$QUIET" -eq 1 ] || echo "$@"; }
warn() { echo "$@" >&2; }

# ─── Install routine (called once per target host dir) ────────
install_at() {
  local host_dir="$1"
  local label="$2"
  mkdir -p "$host_dir"

  local perry_target="$host_dir/perry"

  # Step 1: ensure perry/ symlink at the target
  if [ "$SETUP_DIR" = "$perry_target" ]; then
    log "  [$label] perry/ already lives at $perry_target (running from there)"
  elif [ -L "$perry_target" ]; then
    local resolved="$(cd "$perry_target" && pwd -P)"
    if [ "$resolved" = "$SOURCE_DIR" ]; then
      log "  [$label] perry/ symlink already points at $SOURCE_DIR"
    else
      warn "  [$label] perry/ symlink points at $resolved"
      warn "  [$label] this script lives at $SOURCE_DIR — leaving existing link in place."
      warn "  [$label] rm \"$perry_target\" and re-run if you want to repoint."
    fi
  elif [ -d "$perry_target" ]; then
    warn "  [$label] perry/ exists at $perry_target (not a symlink) — leaving in place."
    warn "  [$label] Sync new content with: rsync -a --delete \"$SOURCE_DIR/\" \"$perry_target/\""
  elif [ -e "$perry_target" ]; then
    warn "  [$label] $perry_target exists and is not a directory — refusing to touch."
    return 1
  else
    log "  [$label] linking perry/ -> $SOURCE_DIR"
    ln -snf "$SOURCE_DIR" "$perry_target"
  fi

  # Step 2: link child skills as siblings
  if [ ! -d "$perry_target" ]; then
    warn "  [$label] perry directory not found at $perry_target — aborting child link"
    return 1
  fi

  local linked=() skipped=()
  for child_dir in "$perry_target"/*/; do
    [ -f "$child_dir/SKILL.md" ] || continue
    local name="$(basename "$child_dir")"
    local target="$host_dir/$name"

    if [ -L "$target" ]; then
      local existing="$(readlink "$target")"
      if [ "$existing" = "perry/$name" ]; then
        continue
      fi
      ln -snf "perry/$name" "$target"
      linked+=("$name")
    elif [ ! -e "$target" ]; then
      ln -snf "perry/$name" "$target"
      linked+=("$name")
    else
      skipped+=("$name (real file/dir at $target)")
    fi
  done

  [ ${#linked[@]} -gt 0 ] && log "  [$label] linked child skills: ${linked[*]}"
  [ ${#skipped[@]} -gt 0 ] && warn "  [$label] skipped: ${skipped[*]}"
  return 0
}

# ─── 1. Claude Code install (always) ─────────────────────────
if [ "$LOCAL" -eq 1 ]; then
  CC_DIR="$(pwd)/.claude/skills"
else
  CC_DIR="$HOME/.claude/skills"
fi
install_at "$CC_DIR" "claude-code"

# ─── 2. Codex install (with --codex) ─────────────────────────
if [ "$CODEX" -eq 1 ]; then
  CODEX_DIR="$HOME/.agents/skills"
  install_at "$CODEX_DIR" "codex"

  # Shell-export hints — Codex install at the default ~/.agents/skills/perry
  # doesn't strictly need PERRY_HOME (the bin scripts can self-locate), but
  # setting it makes SKILL.md prose unambiguous and avoids edge cases.
  if [ -z "${PERRY_HOME:-}" ] || [ -z "${PERRY_HOST:-}" ]; then
    log ""
    log "  [codex] Recommended shell exports (so SKILL.md $PERRY_HOME refs are unambiguous):"
    [ -z "${PERRY_HOME:-}" ] && log "    export PERRY_HOME=\"$CODEX_DIR/perry\""
    [ -z "${PERRY_HOST:-}" ] && log "    export PERRY_HOST=codex-cli"
  fi
fi

# ─── 3. Summary ──────────────────────────────────────────────
log ""
log "Perry ready."
log "  source       : $SOURCE_DIR"
log "  claude-code  : $CC_DIR"
[ "$CODEX" -eq 1 ] && log "  codex        : $HOME/.agents/skills"
log "  skills       : /perry, /okr, /pmo, /design"
log ""
log "  Claude Code: invoke /perry inside a project for the combined dashboard."
[ "$CODEX" -eq 1 ] && log "  Codex CLI  : invoke /skills, then pick perry — or type \$perry to mention."
